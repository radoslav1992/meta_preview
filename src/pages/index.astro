---
import Layout from '../layouts/Layout.astro';

// ── Server-side data extraction ──
const request = Astro.request;
const headers = request.headers;

// IP Address
const rawIp =
  headers.get('x-forwarded-for')?.split(',')[0]?.trim() ||
  headers.get('x-real-ip') ||
  headers.get('cf-connecting-ip') ||
  Astro.clientAddress ||
  'Unknown';

// Detect localhost / loopback IPs
const localhostIps = ['::1', '127.0.0.1', '::ffff:127.0.0.1', 'localhost'];
const isLocalhost = localhostIps.includes(rawIp);
const ip = rawIp;
const ipDisplayNote = isLocalhost
  ? 'You are viewing this from localhost. Your real public IP will be shown when this site is deployed to a server.'
  : 'This is your public-facing IP address. Websites use it to approximate your location, ISP, and can link your browsing sessions together.';

// User-Agent parsing
const ua = headers.get('user-agent') || 'Unknown';

function parseOS(userAgent: string): string {
  if (/Windows NT 10/.test(userAgent)) return 'Windows 10/11';
  if (/Windows NT 6\.3/.test(userAgent)) return 'Windows 8.1';
  if (/Windows NT 6\.2/.test(userAgent)) return 'Windows 8';
  if (/Windows NT 6\.1/.test(userAgent)) return 'Windows 7';
  if (/Windows/.test(userAgent)) return 'Windows';
  if (/Mac OS X 10[._]15/.test(userAgent)) return 'macOS Catalina+';
  if (/Mac OS X 11/.test(userAgent) || /Mac OS X 12/.test(userAgent) || /Mac OS X 13/.test(userAgent) || /Mac OS X 14/.test(userAgent) || /Mac OS X 15/.test(userAgent)) return 'macOS (modern)';
  if (/Mac OS X/.test(userAgent)) return 'macOS';
  if (/CrOS/.test(userAgent)) return 'Chrome OS';
  if (/Android/.test(userAgent)) return 'Android';
  if (/iPhone|iPad|iPod/.test(userAgent)) return 'iOS';
  if (/Linux/.test(userAgent)) return 'Linux';
  return 'Unknown OS';
}

function parseBrowser(userAgent: string): string {
  if (/Edg\//.test(userAgent)) return 'Microsoft Edge';
  if (/OPR\/|Opera/.test(userAgent)) return 'Opera';
  if (/Brave/.test(userAgent)) return 'Brave';
  if (/Vivaldi/.test(userAgent)) return 'Vivaldi';
  if (/Firefox\//.test(userAgent)) return 'Firefox';
  if (/Chrome\//.test(userAgent) && !/Chromium/.test(userAgent)) return 'Google Chrome';
  if (/Safari\//.test(userAgent) && !/Chrome/.test(userAgent)) return 'Safari';
  return 'Unknown Browser';
}

function parseDevice(userAgent: string): string {
  if (/Mobile|Android.*Mobile|iPhone|iPod/.test(userAgent)) return 'Mobile';
  if (/iPad|Android(?!.*Mobile)|Tablet/.test(userAgent)) return 'Tablet';
  return 'Desktop';
}

const os = parseOS(ua);
const browser = parseBrowser(ua);
const device = parseDevice(ua);

// Additional server-side headers
const acceptLang = headers.get('accept-language')?.split(',')[0] || 'Unknown';
const dnt = headers.get('dnt');
const secChUa = headers.get('sec-ch-ua') || null;
const secChUaPlatform = headers.get('sec-ch-ua-platform')?.replace(/"/g, '') || null;
const secChUaMobile = headers.get('sec-ch-ua-mobile') || null;
const referer = headers.get('referer') || 'Direct visit';
const connection = headers.get('connection') || 'Unknown';
---


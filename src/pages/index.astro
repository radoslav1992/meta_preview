  <script>
    // ── Client-side fingerprinting ──
    document.addEventListener('DOMContentLoaded', () => {
      let leakCount = 0;

      // Helper: set value in a DOM element
      function setValue(id: string, value: string) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
      }

      // ── Screen & Display ──
      setValue('val-resolution', `${screen.width} × ${screen.height}`);
      setValue('val-viewport', `${window.innerWidth} × ${window.innerHeight}`);
      setValue('val-color-depth', `${screen.colorDepth}-bit`);
      setValue('val-pixel-ratio', `${window.devicePixelRatio}x`);
      setValue('val-touch', 'ontouchstart' in window || navigator.maxTouchPoints > 0 ? `Yes (${navigator.maxTouchPoints} points)` : 'No');
      leakCount += 5;

      // ── Locale & Timezone ──
      setValue('val-language', navigator.language || 'Unknown');
      setValue('val-timezone', Intl.DateTimeFormat().resolvedOptions().timeZone || 'Unknown');
      const offset = new Date().getTimezoneOffset();
      const sign = offset <= 0 ? '+' : '-';
      const absOffset = Math.abs(offset);
      setValue('val-utc-offset', `UTC${sign}${String(Math.floor(absOffset / 60)).padStart(2, '0')}:${String(absOffset % 60).padStart(2, '0')}`);
      leakCount += 3;

      // ── Privacy Settings ──
      setValue('val-cookies', navigator.cookieEnabled ? '✅ Enabled' : '❌ Disabled');
      try {
        localStorage.setItem('__test', '1');
        localStorage.removeItem('__test');
        setValue('val-localstorage', '✅ Available');
      } catch {
        setValue('val-localstorage', '❌ Blocked');
      }
      leakCount += 2;

      // ── Ad blocker detection ──
      const adTest = document.createElement('div');
      adTest.innerHTML = '&nbsp;';
      adTest.className = 'adsbox ad-placement ad-banner textads banner-ads';
      adTest.style.cssText = 'position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;';
      document.body.appendChild(adTest);
      setTimeout(() => {
        const blocked = adTest.offsetHeight === 0 || adTest.clientHeight === 0;
        setValue('val-adblock', blocked ? '✅ Detected' : '❌ Not detected');
        document.body.removeChild(adTest);
      }, 100);

      // ── Hardware ──
      setValue('val-cpu-cores', String((navigator as any).hardwareConcurrency || 'Unknown'));
      setValue('val-ram', (navigator as any).deviceMemory ? `${(navigator as any).deviceMemory} GB` : 'Not available');

      // Platform detection: navigator.platform returns 'MacIntel' even on Apple Silicon.
      // Use the modern userAgentData API + WebGL renderer to detect the real architecture.
      async function detectPlatform(): Promise<string> {
        // Try modern User-Agent Client Hints API first
        if ('userAgentData' in navigator) {
          try {
            const uaData = await (navigator as any).userAgentData.getHighEntropyValues(['architecture', 'platform', 'model', 'bitness']);
            const platform = uaData.platform || 'Unknown';
            const arch = uaData.architecture || '';
            const bitness = uaData.bitness || '';
            if (platform === 'macOS' && arch === 'arm') {
              return `macOS (Apple Silicon, ${bitness}-bit)`;
            } else if (platform === 'macOS' && arch === 'x86') {
              return `macOS (Intel x86, ${bitness}-bit)`;
            } else if (arch) {
              return `${platform} (${arch}${bitness ? `, ${bitness}-bit` : ''})`;
            }
            return platform;
          } catch {
            // Fall through to WebGL detection
          }
        }

        // Fallback: check WebGL renderer for Apple GPU (indicates Apple Silicon)
        try {
          const c = document.createElement('canvas');
          const gl = c.getContext('webgl');
          if (gl) {
            const dbg = gl.getExtension('WEBGL_debug_renderer_info');
            if (dbg) {
              const renderer = gl.getParameter(dbg.UNMASKED_RENDERER_WEBGL) || '';
              if (/Apple M\d/i.test(renderer)) {
                const match = renderer.match(/Apple M\d+[\w\s]*/i);
                return `macOS (${match ? match[0].trim() : 'Apple Silicon'})`;
              }
            }
          }
        } catch {}

        // Final fallback
        return navigator.platform || 'Unknown';
      }

      detectPlatform().then((platform) => {
        setValue('val-platform', platform);
      });
      leakCount += 3;

      // ── Battery ──
      if ('getBattery' in navigator) {
        (navigator as any).getBattery().then((battery: any) => {
          const pct = Math.round(battery.level * 100);
          const charging = battery.charging ? ' (Charging)' : '';
          setValue('val-battery', `${pct}%${charging}`);
          leakCount += 1;
          updateScore();
        }).catch(() => {
          setValue('val-battery', 'Not available');
        });
      } else {
        setValue('val-battery', 'Not available');
      }

      // ── Connection Info ──
      const conn = (navigator as any).connection || (navigator as any).mozConnection || (navigator as any).webkitConnection;
      if (conn) {
        setValue('val-protocol', window.location.protocol === 'https:' ? 'HTTPS' : 'HTTP');
        setValue('val-connection-type', conn.effectiveType || 'Unknown');
        setValue('val-downlink', conn.downlink ? `${conn.downlink} Mbps` : 'Unknown');
        leakCount += 3;
      } else {
        setValue('val-protocol', window.location.protocol === 'https:' ? 'HTTPS' : 'HTTP');
        setValue('val-connection-type', 'Not available');
        setValue('val-downlink', 'Not available');
        leakCount += 1;
      }

      // ── Canvas Fingerprint ──
      try {
        const canvas = document.createElement('canvas');
        canvas.width = 280;
        canvas.height = 60;
        const ctx = canvas.getContext('2d');
        if (ctx) {
          // Background
          ctx.fillStyle = '#0c1018';
          ctx.fillRect(0, 0, 280, 60);

          // Text rendering (unique per GPU/OS/font)
          ctx.textBaseline = 'top';
          ctx.font = '14px Arial';
          ctx.fillStyle = '#ff3b5c';
          ctx.fillText('🔒 Tracker Fingerprint Test', 8, 6);

          ctx.font = 'bold 11px monospace';
          ctx.fillStyle = '#00e5ff';
          ctx.fillText('abcdefghijklmnopqrstuvwxyz0123456789', 8, 28);

          // Geometry
          ctx.beginPath();
          ctx.arc(250, 40, 14, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(168, 85, 247, 0.6)';
          ctx.fill();

          ctx.strokeStyle = '#f59e0b';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(200, 50);
          ctx.lineTo(220, 30);
          ctx.lineTo(240, 50);
          ctx.closePath();
          ctx.stroke();

          // Blend
          ctx.globalCompositeOperation = 'multiply';
          ctx.fillStyle = 'rgba(255, 59, 92, 0.3)';
          ctx.fillRect(60, 10, 160, 40);
          ctx.globalCompositeOperation = 'source-over';

          // Hash the data URL
          const dataUrl = canvas.toDataURL();
          let hash = 0;
          for (let i = 0; i < dataUrl.length; i++) {
            const char = dataUrl.charCodeAt(i);
            hash = ((hash << 5) - hash) + char;
            hash |= 0; // Convert to 32-bit int
          }
          const hexHash = (hash >>> 0).toString(16).padStart(8, '0');
          const fullHash = `${hexHash}-${dataUrl.length.toString(16)}`;

          setValue('val-canvas-hash', fullHash);
          leakCount += 1;

          // Display the canvas
          const preview = document.getElementById('canvas-preview');
          if (preview) {
            preview.appendChild(canvas);
          }
        }
      } catch {
        setValue('val-canvas-hash', 'Blocked / Not available');
      }

      // ── WebGL Fingerprint ──
      try {
        const glCanvas = document.createElement('canvas');
        const gl = glCanvas.getContext('webgl') || glCanvas.getContext('experimental-webgl');
        if (gl) {
          const debugInfo = (gl as WebGLRenderingContext).getExtension('WEBGL_debug_renderer_info');
          if (debugInfo) {
            const renderer = (gl as WebGLRenderingContext).getParameter(debugInfo.UNMASKED_RENDERER_WEBGL);
            const vendor = (gl as WebGLRenderingContext).getParameter(debugInfo.UNMASKED_VENDOR_WEBGL);
            setValue('val-webgl-renderer', renderer || 'Unknown');
            setValue('val-webgl-vendor', vendor || 'Unknown');
            leakCount += 2;
          } else {
            setValue('val-webgl-renderer', 'Debug info blocked');
            setValue('val-webgl-vendor', 'Debug info blocked');
          }
        } else {
          setValue('val-webgl-renderer', 'WebGL not available');
          setValue('val-webgl-vendor', 'WebGL not available');
        }
      } catch {
        setValue('val-webgl-renderer', 'Blocked');
        setValue('val-webgl-vendor', 'Blocked');
      }

      // ── Audio Fingerprint ──
      try {
        const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const oscillator = audioCtx.createOscillator();
        const analyser = audioCtx.createAnalyser();
        const gainNode = audioCtx.createGain();
        const scriptProcessor = audioCtx.createScriptProcessor(4096, 1, 1);

        gainNode.gain.value = 0; // Mute
        oscillator.type = 'triangle';
        oscillator.frequency.setValueAtTime(10000, audioCtx.currentTime);

        oscillator.connect(analyser);
        analyser.connect(scriptProcessor);
        scriptProcessor.connect(gainNode);
        gainNode.connect(audioCtx.destination);

        oscillator.start(0);

        scriptProcessor.onaudioprocess = function (ev) {
          const output = ev.inputBuffer.getChannelData(0);
          let hash = 0;
          for (let i = 0; i < output.length; i += 100) {
            hash += Math.abs(output[i]);
          }
          const audioHash = hash.toFixed(6).replace('.', '');
          setValue('val-audio-hash', `0x${parseInt(audioHash).toString(16).padStart(8, '0')}`);
          leakCount += 1;

          // Cleanup
          oscillator.stop();
          scriptProcessor.disconnect();
          analyser.disconnect();
          gainNode.disconnect();
          audioCtx.close();
          updateScore();
        };
      } catch {
        setValue('val-audio-hash', 'Not available');
      }

      // ── Count server-side leaks ──
      // IP, OS, browser, device, accept-lang, dnt, referrer, connection = 8
      leakCount += 8;

      // ── Update leak count & score ──
      function updateScore() {
        const countEl = document.getElementById('leak-count');
        if (countEl) countEl.textContent = String(leakCount);

        // Score: higher = more exposed (0-100)
        const score = Math.min(Math.round((leakCount / 30) * 100), 100);
        const scoreNumber = document.getElementById('score-number');
        const scoreRing = document.getElementById('score-ring') as SVGCircleElement | null;
        const scoreVerdict = document.getElementById('score-verdict');

        if (scoreNumber) scoreNumber.textContent = `${score}`;
        if (scoreRing) {
          const circumference = 2 * Math.PI * 70;
          const offset = circumference - (score / 100) * circumference;
          scoreRing.style.strokeDasharray = String(circumference);
          scoreRing.style.strokeDashoffset = String(offset);

          if (score >= 70) {
            scoreRing.style.stroke = '#ff3b5c';
          } else if (score >= 40) {
            scoreRing.style.stroke = '#f59e0b';
          } else {
            scoreRing.style.stroke = '#22c55e';
          }
        }

        if (scoreVerdict) {
          if (score >= 70) {
            scoreVerdict.textContent = '⚠️ Highly Exposed';
            scoreVerdict.style.color = '#ff3b5c';
          } else if (score >= 40) {
            scoreVerdict.textContent = '⚡ Moderately Exposed';
            scoreVerdict.style.color = '#f59e0b';
          } else {
            scoreVerdict.textContent = '✅ Reasonably Protected';
            scoreVerdict.style.color = '#22c55e';
          }
        }
      }

      // Initial score update after a short delay
      setTimeout(updateScore, 500);
    });
  </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';

const seoTitle = "404 - Page Not Found | What Do Trackers See?";
const seoDescription = "The page you are looking for has been moved or no longer exists.";
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="container">
    <div class="page-header" style="margin-top: 8rem; margin-bottom: 8rem; border-bottom: none;">
      <div style="font-size: 4rem; margin-bottom: 1rem; filter: drop-shadow(0 0 20px rgba(255, 59, 92, 0.4));">🚫</div>
      <h1 style="font-size: 5rem; background: var(--gradient-danger); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0;">404</h1>
      <h2 style="font-size: 2rem; margin-bottom: 1.5rem; color: var(--text-primary);">Page Not Found</h2>
      <p class="page-header__subtitle" style="margin-bottom: 3rem;">
        It looks like the track you were following led to a dead end. The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>
      
      <div class="cta-buttons">
        <a class="btn btn--primary" href="/">
          &#8592; Return to Safety
        </a>
      </div>
    </div>
  </main>
</Layout>

---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "What Do Trackers See? | Free Privacy Audit Tool",
  description = "Discover exactly what advertisers and trackers know about you. Free instant privacy audit shows your IP, location, browser fingerprint, and more.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-image.png", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-179C1N464V"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-179C1N464V');
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="privacy audit, browser fingerprint, IP address lookup, tracker detection, online privacy, VPN, digital fingerprint, canvas fingerprint, screen resolution tracking, ISP detection, privacy tool" />
    <meta name="author" content="What Do Trackers See?" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="What Do Trackers See?" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "What Do Trackers See?",
      "description": description,
      "url": canonicalURL,
      "applicationCategory": "SecurityApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "What Do Trackers See?"
      }
    })} />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4657327478747074"
      crossorigin="anonymous"
    ></script>

    <!-- Styles -->
    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body>
    <!-- Top Navigation Header -->
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-logo">
          <span class="site-logo__icon">👁️</span>
          <span class="site-logo__text">What Do Trackers See?</span>
        </a>
        <nav class="site-nav">
          <a href="/knowledge-base" class="site-nav__link">Knowledge Base</a>
          <a href="/privacy" class="site-nav__link">Privacy Policy</a>
        </nav>
      </div>
    </header>

    <slot />
  </body>
</html>
